# AI Generator Backend Environment Variables
# Place this file in apps/website/backend/ai-generator-backend/
# DO NOT commit actual values to version control

# OpenAI API key for chat completions
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI request timeout in milliseconds (default: 25000)
OPENAI_TIMEOUT_MS=25000

# Secret token for health endpoint authentication
HEALTH_SECRET=your_health_check_secret_here

# Port to listen on (Railway/Render will override this)
PORT=5000

# Bind address (default: 0.0.0.0; normally leave unset on Railway)
HOST=0.0.0.0
