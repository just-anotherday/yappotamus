# apps/website/.env.staging (Cloudflare Workers + Docker Backend)
NODE_ENV=staging
D1_DATABASE_NAME=yappotamus_staging
D1_DATABASE_ID=<STAGING_D1_DB_ID>
WORKER_SECRET_KEY=<STAGING_CLOUDFLARE_WORKER_SECRET>
ORIGIN_SERVER_URL=https://backend-staging.website.yourdomain.com
ENABLE_DEBUG_LOGGING=true

# 🔒 D1 credentials & Worker secrets must be bound via `wrangler.toml` or Cloudflare Pages secrets
