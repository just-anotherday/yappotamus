# apps/website/.env.production (Cloudflare Workers + Docker Backend)
NODE_ENV=production
D1_DATABASE_NAME=yappotamus_production
D1_DATABASE_ID=<PRODUCTION_D1_DB_ID>
WORKER_SECRET_KEY=<PRODUCTION_CLOUDFLARE_WORKER_SECRET>
ORIGIN_SERVER_URL=https://backend.website.yourdomain.com
ENABLE_DEBUG_LOGGING=false

# 🔒 D1 credentials & Worker secrets must be bound via `wrangler.toml` or Cloudflare Pages secrets
