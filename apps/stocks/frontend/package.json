{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "build:opennext": "npx opennextjs-cloudflare build",
    "build:cf": "npm run build:opennext",
    "deploy:cf": "npm run build:opennext && npx opennextjs-cloudflare deploy",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test:reports": "node --experimental-strip-types --test lib/reportPresentation.test.mjs",
    "test:watchlist": "node --experimental-strip-types --test lib/watchlistPresentation.test.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  }
}
