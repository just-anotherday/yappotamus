# apps/stocks/.env.staging (Backend + Frontend overrides)
NODE_ENV=staging
PORT=3001
DATABASE_URL=<STAGING_DB_CONNECTION_STRING>
JWT_SECRET=<STAGING_JWT_SECRET>
CORS_ORIGINS=https://stocks-staging.yapvibes.com,http://localhost:3000
FINNHUB_API_KEY=<STAGING_FINNHUB_API_KEY>

# OLLAMA_BASE_URL= (optional, omit in prod if not using)
# OLLAMA_MODEL= (optional)

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_API_BASE=https://api-staging.yapvibes.com
NEXT_PUBLIC_WS_URL=wss://api-staging.yapvibes.com/ws

# 🔒 Move DATABASE_URL, JWT_SECRET, FINNHUB_API_KEY to Render/Cloudflare Pages Environment Secrets
