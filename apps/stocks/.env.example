# FastAPI Backend Configuration (Stocks App)

# Database Connection
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/news

# CORS Origins (comma-separated, production domains)
CORS_ORIGINS=http://localhost:3000,https://stocks.yapvibes.com

# Finnhub API Key for market data
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE

# Ollama AI Configuration (optional, for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_S=540
OLLAMA_TIMEOUT_SMALL_S=900
OLLAMA_TIMEOUT_LARGE_S=1800
ANALYSIS_TIMEOUT_S=1800

# WebSocket Reconnect Settings
WS_RECONNECT_BACKOFF_S=1
WS_RECONNECT_MAX_BACKOFF_S=30

# Quote Cache
QUOTE_CACHE_MAX_SIZE=256
