# =============================================================
# YapVibes Stocks Backend - Environment Configuration
# =============================================================
# Copy to .env and fill in real values.
# NEVER commit .env with real secrets.
# =============================================================

# ------------------------------------------------------------------
# Database (Supabase PostgreSQL for production)
# ------------------------------------------------------------------
# Development:  postgresql+asyncpg://postgres:password@localhost:5432/news
# Production:   postgresql+asyncpg://<user>:<pass>@<project>.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/news

# ------------------------------------------------------------------
# AI Provider Selection
# ------------------------------------------------------------------
# Options: ollama (default, local dev), openai (production)
AI_PROVIDER=ollama

# Ollama (local development)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SMALL_S=900
OLLAMA_TIMEOUT_LARGE_S=1200
OLLAMA_MAX_RETRIES=3

# OpenAI (production)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------------------------------
# Market Data
# ------------------------------------------------------------------
FINNHUB_API_KEY=d8f489hr01qub7kfq8v0d8f489hr01qub7kfq8vg

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://yapvibes.com,https://stocks.yapvibes.com,https://projects.yapvibes.com,https://yapvibes-stocks.pages.dev

# ------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX_REQS=60

# ------------------------------------------------------------------
# AI Worker
# ------------------------------------------------------------------
AI_WORKER_POLL_INTERVAL_S=10
AI_WORKER_MAX_CONCURRENT=2

# ------------------------------------------------------------------
# WebSocket Reconnect Settings
# ------------------------------------------------------------------
WS_RECONNECT_BACKOFF_S=1
WS_RECONNECT_MAX_BACKOFF_S=30

# ------------------------------------------------------------------
# Quote Cache
# ------------------------------------------------------------------
QUOTE_CACHE_MAX_SIZE=256
LIVE_PRICE_POLL_S=15
MARKET_DATA_BATCH_SIZE=50
PM_FETCH_INTERVAL_S=30
PM_MAX_CONCURRENCY=3
MARKET_DATA_BACKOFF_INITIAL_S=5
MARKET_DATA_BACKOFF_MAX_S=120
MARKET_DATA_JITTER_S=1.0
FINNHUB_REQUESTS_PER_MINUTE=55
# Deprecated compatibility setting; regular quotes now use batched downloads.
YF_PER_TICKER_DELAY_S=0.6
