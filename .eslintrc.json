{
  "root": true,
  "ignorePatterns": ["**/node_modules/", "**/dist/", "**/.next/", "**/build/", "**/alembic/"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "@typescript-eslint/no-unused-vars": "warn",
        "@typescript-eslint/no-explicit-any": "warn"
      }
    }
  ]
}
